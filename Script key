function AutoChestFunc()
  spawn(function()
    while getgenv().AutoChest do
      task.wait(0.3)
      pcall(function()
        local chests={}
        for _,v in pairs(workspace:GetDescendants()) do if v.Name:lower():find("chest") and v:IsA("BasePart") then table.insert(chests,v) end end
        if #chests==0 then wait(1) return end
        table.sort(chests,function(a,b) return (a.Position-game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < (b.Position-game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude end)
        for _,part in ipairs(chests) do
          if not getgenv().AutoChest then break end
          local dist=(part.Position-game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
          if dist>150 then TweenReto(part.CFrame,350) else game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame=part.CFrame wait(0.2) firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, part, 0) firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, part, 1) end
        end
      end)
    end
  end)
end

function AutoStoreFunc()
  spawn(function()
    while getgenv().AutoStore do
      task.wait(1)
      pcall(function()
        for _,tool in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
          if tool.ToolTip=="Blox Fruit" then
            local fname=tool.Name:gsub(" Fruit","")
            local has=false
            local ok,fruits=pcall(function() return game.ReplicatedStorage.Remotes.CommF_:InvokeServer("GetFruits") end)
            if ok and fruits then for _,f in pairs(fruits) do if f.Name==fname then has=true break end end end
            if not has then game.ReplicatedStorage.Remotes.CommF_:InvokeServer("StoreFruit",fname,tool) end
          end
        end
      end)
    end
  end)
end

