function HasQuest(M)
  local g=game.Players.LocalPlayer.PlayerGui.Main.Quest
  if not g.Visible then return false end
  return string.find(g.Container.QuestTitle.Title.Text:lower(),M:lower())~=nil
end

function TweenReto(Target,Speed)
  Speed=Speed or 320
  local char=game.Players.LocalPlayer.Character
  if not char then return end
  local hrp=char:FindFirstChild("HumanoidRootPart")
  if not hrp then return end
  if not getgenv().AutoFarm and not getgenv().AutoSaber and not getgenv().AutoChest and not getgenv().AutoFruit then return end
  local d=(hrp.Position-Target.Position).Magnitude
  if d<120 then hrp.CFrame=Target return end
  CurrentTween=game:GetService("TweenService"):Create(hrp,TweenInfo.new(d/Speed,Enum.EasingStyle.Linear),{CFrame=Target})
  CurrentTween:Play()
  repeat task.wait() until not getgenv().AutoFarm and not getgenv().AutoSaber and not getgenv().AutoChest and not getgenv().AutoFruit or CurrentTween.PlaybackState==Enum.PlaybackState.Completed
  if CurrentTween then CurrentTween:Cancel() CurrentTween=nil end
end

function GetQuest()
  local lvl=game.Players.LocalPlayer.Data.Level.Value
  local sel=Quests[1]
  for _,v in ipairs(Quests) do if lvl>=v.L then sel=v end end
  return sel
end

function AuraLoop()
  if getgenv().AuraRunning then return end
  getgenv().AuraRunning=true
  spawn(function()
    local Net=game:GetService("ReplicatedStorage").Modules.Net
    while getgenv().Aura or getgenv().AutoFarm do
      task.wait(0.03)
      pcall(function()
        local hrp=game.Players.LocalPlayer.Character.HumanoidRootPart
        if not hrp then return end
        Net["RE/RegisterAttack"]:FireServer(0)
        for _,mob in pairs(workspace.Enemies:GetChildren()) do
          if mob:FindFirstChild("HumanoidRootPart") and mob.Humanoid.Health>0 and (mob.HumanoidRootPart.Position-hrp.Position).Magnitude<=getgenv().AuraDist then
            mob.HumanoidRootPart.Size=Vector3.new(60,60,60)
            mob.HumanoidRootPart.CanCollide=false
            Net["RE/RegisterHit"]:FireServer(mob.HumanoidRootPart,{{mob.HumanoidRootPart,mob.Humanoid}})
          end
        end
      end)
    end
    getgenv().AuraRunning=false
  end)
end

function StartFarm()
  spawn(function()
    while getgenv().AutoFarm do
      task.wait(0.15)
      pcall(function()
        if not getgenv().AutoFarm then return end
        local Q=GetQuest()
        local hrp=game.Players.LocalPlayer.Character.HumanoidRootPart
        if not HasQuest(Q.N) then
          TweenReto(Q.PQ) wait(0.5)
          game.ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest",Q.Q,Q.QN) wait(1) return
        end
        local Mob=nil
        for _,v in pairs(workspace.Enemies:GetChildren()) do if v.Name==Q.N and v.Humanoid.Health>0 then Mob=v break end end
        if Mob then
          local BringPos=Mob.HumanoidRootPart.CFrame
          local PosFicar=BringPos*CFrame.new(0,15,6)
          TweenReto(PosFicar)
          repeat task.wait()
            if not getgenv().AutoFarm then break end
            if not game.Players.LocalPlayer.Character:FindFirstChildOfClass("Tool") then
              for _,t in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do if t.ToolTip=="Melee" then game.Players.LocalPlayer.Character.Humanoid:EquipTool(t) break end end
            end
            for _,m in pairs(workspace.Enemies:GetChildren()) do
              if m.Name==Q.N and m:FindFirstChild("HumanoidRootPart") and m.Humanoid.Health>0 and (m.HumanoidRootPart.Position-BringPos.Position).Magnitude<350 then
                m.HumanoidRootPart.CFrame=BringPos
                m.Humanoid.WalkSpeed=0
              end
            end
            hrp.CFrame=PosFicar
            hrp.Velocity=Vector3.new(0,0,0)
          until not getgenv().AutoFarm or not Mob.Parent or Mob.Humanoid.Health<=0 or not HasQuest(Q.N)
        else
          TweenReto(Q.PM*CFrame.new(math.random(-25,25),0,math.random(-25,25))*CFrame.new(0,15,0)) wait(0.5)
        end
      end)
    end
  end)
end

